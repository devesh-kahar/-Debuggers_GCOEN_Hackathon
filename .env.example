# SafeGuard App - API Keys Configuration
# Copy this file to .env and fill in your actual API keys

# ============================================
# GOOGLE MAPS PLATFORM (REQUIRED)
# ============================================
# Get from: https://console.cloud.google.com
# Steps:
# 1. Create new project
# 2. Enable: Maps SDK for Android, Maps SDK for iOS, Directions API, Places API, Geocoding API
# 3. Go to Credentials → Create API Key
# 4. Copy the key here
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ============================================
# GOOGLE CUSTOM SEARCH (For Privacy Scanner)
# ============================================
# API Key: Same as above (Google Cloud Console)
# Search Engine ID: https://programmablesearchengine.google.com
# Steps:
# 1. Create new search engine
# 2. Select "Search the entire web"
# 3. Copy the Search Engine ID
GOOGLE_CUSTOM_SEARCH_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=YOUR_SEARCH_ENGINE_ID_HERE

# ============================================
# CRIMEOMETER (Optional - USA Crime Data)
# ============================================
# Get from: https://www.crimeometer.com/crime-data-api
# Steps:
# 1. Sign up for free account
# 2. Get API key from dashboard
# Note: Leave empty to use UK Police API instead (no key needed)
CRIMEOMETER_API_KEY=

# ============================================
# HAVE I BEEN PWNED (Optional - Privacy Scanner)
# ============================================
# Get from: https://haveibeenpwned.com/API/Key
# Steps:
# 1. Purchase API key ($3.50/month)
# Note: Leave empty to use free tier (works fine for hackathon)
HIBP_API_KEY=

# ============================================
# OPENWEATHER (Optional - Weather Data)
# ============================================
# Get from: https://openweathermap.org/api
# Steps:
# 1. Sign up for free account
# 2. Get API key from dashboard
# Note: Optional feature, not critical
OPENWEATHER_API_KEY=
